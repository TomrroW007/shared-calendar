# =========================================================================
# Shared Calendar - Environment Variables Configuration Template
# =========================================================================

# Database Connection (MongoDB)
MONGODB_URI=mongodb://localhost:27017/shared-calendar

# Secure Session Key (JWT Encryption)
# Run `openssl rand -base64 32` to generate a secure secret key.
JWT_SECRET=your_jwt_secret_key_here

# Pusher Channels Credentials (Backend Server SDK)
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=ap1

# Pusher Channels Credentials (Client-side Web SDK)
# Prefix 'NEXT_PUBLIC_' makes these variables accessible in client-side JS.
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
NEXT_PUBLIC_PUSHER_CLUSTER=ap1
